# Chat Example .env Reference
#
# Standard TAC configuration should be in ../.env (parent directory)
# See ../.env.example for all required TAC variables
#
# This file shows ONLY the chat-specific variables needed in addition to standard TAC vars

# Chat Example - Conversations v1 Service SID (starts with IS)
# This is the Twilio Conversations v1 Service SID, NOT the Conversation Orchestrator configuration ID
TWILIO_CONVERSATIONS_SERVICE_SID=ISxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
