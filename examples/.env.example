# Twilio Agent Connect Environment Variables
# Copy this file to .env and update with your actual values

# ============================================================================
# TAC Core Configuration
# ============================================================================

# (Required) TAC environment: dev, stage, or prod
TWILIO_TAC_ENVIRONMENT=prod
# (Required) Twilio Account SID from Twilio Console
TWILIO_TAC_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# (Required) Twilio Auth Token from Twilio Console
TWILIO_TAC_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# (Required) Twilio phone number for Voice (inbound) and SMS (send/receive)
TWILIO_TAC_PHONE_NUMBER=+1xxxxxxxxxx
# (Optional) Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
TWILIO_TAC_LOG_LEVEL=DEBUG

# ============================================================================
# Twilio Memory Service Configuration (Optional)
# ============================================================================
# The following 3 are required if Memory is enabled:

# (Optional) Memory Store ID (starts with mem_store_ or mem_service_)
TWILIO_TAC_MEMORY_STORE_ID=mem_store_xxxxxxxxxxxxxxxxxxxxxxxxxx
# (Optional) Twilio API Key SID (starts with SK)
TWILIO_TAC_MEMORY_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# (Optional) Twilio API Key Secret
TWILIO_TAC_MEMORY_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optional) Comma-separated list of trait groups to include in profile retrieval
TWILIO_TAC_TRAIT_GROUPS=Contact
# (Optional) Knowledge Base ID for knowledge search functionality
TWILIO_TAC_KNOWLEDGE_BASE_ID=know_knowledgebase_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Twilio Conversation Service Configuration
# ============================================================================

# (Required) Twilio Conversation Service SID (starts with conv_configuration_)
TWILIO_TAC_CONVERSATION_SERVICE_SID=conv_configuration_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Voice Configuration (Optional - for Voice channel)
# ============================================================================

# (Required for Voice) Public domain for Voice WebSocket endpoint (e.g., ngrok domain)
TWILIO_TAC_VOICE_PUBLIC_DOMAIN=your-domain.ngrok.app
# (Optional) Enable active hydration for voice conversations (default: false)
TWILIO_TAC_ENABLE_VOICE_ACTIVE_HYDRATION=true
# (Optional) Flex Workflow SID for voice handoff to human agents
TWILIO_TAC_VOICE_HANDOFF_FLEX_WORKFLOW_SID=WOxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Conversation Intelligence Configuration (OPTIONAL)
# ============================================================================
# Required for processing CI webhook events with tac.process_cintel_event()
# Events are filtered by configuration ID.
 TWILIO_TAC_CI_CONFIGURATION_ID=your_ci_configuration_id_here
 # (OPTIONAL) Enable Observation Operator result processing
 TWILIO_TAC_CI_OBSERVATION_OPERATOR_SID=LYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
 # (OPTIONAL) Enable Conversation summary Operator result processing
 TWILIO_TAC_CI_SUMMARY_OPERATOR_SID=LYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Additional Configuration (Optional - for examples)
# ============================================================================

# (Optional) OpenAI API Key - Required for examples using OpenAI
TWILIO_TAC_OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
